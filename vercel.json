{
  "version": 2,
  "functions": {
    "api/trendyol.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/trendyol",
      "dest": "/api/trendyol.js"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}